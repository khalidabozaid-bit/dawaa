rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // بيانات الأدوية العالمية: متاحة للقراءة للجميع، والكتابة للمسؤولين فقط
    match /medicine_master/{medId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // مؤقتاً لحين تحديد رتبة المدير
    }
    
    // بيانات الجرد الخاصة: معزولة لكل مستخدم على حدة
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /inventory_sync/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // رادار المأموريات
    match /audits/{auditId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
