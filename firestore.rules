rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is an admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // [New] Medicines Collection (V2)
    match /medicines/{medId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // [New] Sync Logs (Global Tracking)
    match /sync_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
      allow update, delete: if false; // Immutable logs
    }

    // Legacy Support (Global Master)
    match /global_master/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // User Profiles & Private Data
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
      
      match /inventory_sync/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Audits & Hub Activity
    match /audits/{auditId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
